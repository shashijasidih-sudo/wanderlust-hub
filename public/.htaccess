<IfModule mod_rewrite.c>
  # ------------------------------------------------------------------
  # 3) Serve real files/directories (JS, CSS, images, sitemap, etc.) as-is
  # ------------------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ------------------------------------------------------------------
  # 4) SPA fallback: hand everything else to React Router (index.html, 200)
  # ------------------------------------------------------------------
  RewriteRule ^ index.html [L]
</IfModule>
