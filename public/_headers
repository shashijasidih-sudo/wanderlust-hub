# Long-term immutable cache for Vite hashed build assets (filenames contain a content hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images bundled under /assets (covered above) or copied to root
/favicon.png
  Cache-Control: public, max-age=2592000
/favicon.ico
  Cache-Control: public, max-age=2592000
/placeholder.svg
  Cache-Control: public, max-age=2592000

# Sitemap & robots — short cache, allow updates to propagate
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=86400

# HTML — never stale-cache; allow CDN revalidation
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
